<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Panel — Jastip Store</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    :root {
      --green: #25D366; --green-dark: #128C7E; --accent: #FF6B35;
      --bg: #F0F2F5; --surface: #fff; --text: #1A1A2E; --text-sub: #6B7280;
      --border: #E5E7EB; --danger: #EF4444; --radius: 14px;
      --shadow: 0 2px 12px rgba(0,0,0,.07);
      --sidebar: 240px;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Plus Jakarta Sans', sans-serif; background: var(--bg); color: var(--text); }

    /* ── LOGIN ─────────────────────────────────────────────── */
    #login-screen {
      min-height: 100vh; display: flex; align-items: center; justify-content: center;
      background: linear-gradient(135deg, #1A1A2E, #0F3460);
    }
    .login-card {
      background: white; border-radius: 20px; padding: 2.5rem;
      width: min(380px, 90vw); box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    }
    .login-logo { display: flex; align-items: center; gap: 10px; margin-bottom: 2rem; }
    .login-logo-icon { width: 40px; height: 40px; background: var(--green); border-radius: 10px; display:flex; align-items:center; justify-content:center; }
    .login-logo-icon svg { fill: white; width: 22px; }
    .login-logo-text { font-weight: 800; font-size: 1.1rem; }
    .login-logo-sub { font-size: 0.75rem; color: var(--text-sub); }
    .login-card h2 { font-size: 1.4rem; margin-bottom: 0.25rem; }
    .login-card p { color: var(--text-sub); font-size: 0.875rem; margin-bottom: 1.75rem; }
    .field { margin-bottom: 1rem; }
    .field label { display:block; font-size: 0.8rem; font-weight: 600; margin-bottom: 6px; }
    .field input {
      width: 100%; padding: 0.7rem 1rem; border: 1.5px solid var(--border);
      border-radius: 10px; font-family: inherit; font-size: 0.9rem; outline: none; transition: border-color .2s;
    }
    .field input:focus { border-color: var(--green); }
    .btn-primary {
      width: 100%; padding: 0.8rem; background: var(--green); color: white;
      border: none; border-radius: 10px; font-family: inherit; font-size: 0.9rem; font-weight: 700;
      cursor: pointer; transition: background .15s;
    }
    .btn-primary:hover { background: var(--green-dark); }
    .login-error { color: var(--danger); font-size: 0.8rem; text-align:center; margin-top: 0.75rem; min-height: 20px; }

    /* ── LAYOUT ────────────────────────────────────────────── */
    #app-screen { display: none; min-height: 100vh; }
    .sidebar {
      position: fixed; top: 0; left: 0; width: var(--sidebar); height: 100vh;
      background: #1A1A2E; color: white; padding: 1.5rem 1rem; display: flex; flex-direction: column; z-index: 100;
    }
    .sidebar-logo { display: flex; align-items: center; gap: 10px; padding: 0 0.5rem; margin-bottom: 2rem; }
    .sidebar-logo-icon { width: 32px; height: 32px; background: var(--green); border-radius: 8px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .sidebar-logo-icon svg { fill: white; width: 18px; }
    .sidebar-logo-text { font-weight: 800; font-size: 0.95rem; }
    .sidebar-logo-sub { font-size: 0.7rem; color: rgba(255,255,255,.4); }
    nav.sidebar-nav { flex: 1; }
    .nav-item {
      display: flex; align-items: center; gap: 10px; padding: 0.65rem 0.75rem;
      border-radius: 10px; cursor: pointer; color: rgba(255,255,255,.6);
      font-size: 0.875rem; font-weight: 500; transition: all .15s; margin-bottom: 4px;
    }
    .nav-item:hover { background: rgba(255,255,255,.08); color: white; }
    .nav-item.active { background: var(--green); color: white; }
    .nav-item svg { flex-shrink: 0; }
    .sidebar-footer { border-top: 1px solid rgba(255,255,255,.1); padding-top: 1rem; }
    .user-info { display: flex; align-items: center; gap: 10px; padding: 0.5rem; margin-bottom: 0.5rem; }
    .user-avatar { width: 32px; height: 32px; background: var(--green); border-radius: 50%; display:flex; align-items:center; justify-content:center; font-weight:700; font-size:0.875rem; color:white; }
    .user-name { font-size: 0.8rem; font-weight: 600; color: rgba(255,255,255,.9); }
    .btn-logout {
      width: 100%; padding: 0.6rem; border-radius: 8px; border: 1px solid rgba(255,255,255,.15);
      background: transparent; color: rgba(255,255,255,.6); cursor: pointer; font-family: inherit;
      font-size: 0.8rem; font-weight: 500; transition: all .15s;
    }
    .btn-logout:hover { background: rgba(255,255,255,.08); color: white; }

    .main-content {
      margin-left: var(--sidebar); padding: 2rem; min-height: 100vh;
    }

    /* ── TOPBAR ─────────────────────────────────────────────── */
    .topbar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 2rem; }
    .page-title { font-size: 1.4rem; font-weight: 800; }
    .page-sub { font-size: 0.8rem; color: var(--text-sub); margin-top: 2px; }

    /* ── STATS CARDS ──────────────────────────────────────────── */
    .stats-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
    .stat-card { background: var(--surface); border-radius: var(--radius); padding: 1.25rem; box-shadow: var(--shadow); }
    .stat-card-label { font-size: 0.75rem; color: var(--text-sub); font-weight: 600; text-transform: uppercase; letter-spacing: .04em; margin-bottom: 8px; }
    .stat-card-num { font-size: 1.75rem; font-weight: 800; }
    .stat-card-num.green { color: var(--green-dark); }
    .stat-card-num.orange { color: var(--accent); }

    /* ── TABLE ──────────────────────────────────────────────── */
    .card-panel { background: var(--surface); border-radius: var(--radius); box-shadow: var(--shadow); overflow: hidden; }
    .card-panel-header {
      padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--border);
      display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem;
    }
    .card-panel-title { font-weight: 700; font-size: 0.95rem; }
    .btn-add {
      display: flex; align-items: center; gap: 6px; padding: 0.6rem 1.25rem;
      background: var(--green); color: white; border: none; border-radius: 8px;
      font-family: inherit; font-size: 0.85rem; font-weight: 700; cursor: pointer;
    }
    .btn-add:hover { background: var(--green-dark); }
    .search-sm {
      padding: 0.55rem 1rem; border: 1.5px solid var(--border); border-radius: 8px;
      font-family: inherit; font-size: 0.85rem; outline: none; min-width: 200px;
    }
    .search-sm:focus { border-color: var(--green); }

    table { width: 100%; border-collapse: collapse; }
    thead { background: #F9FAFB; }
    th { padding: 0.75rem 1.25rem; text-align: left; font-size: 0.75rem; font-weight: 700; color: var(--text-sub); text-transform: uppercase; letter-spacing: .04em; white-space: nowrap; }
    td { padding: 0.85rem 1.25rem; border-top: 1px solid var(--border); font-size: 0.875rem; vertical-align: middle; }
    tr:hover td { background: #F9FAFB; }
    .prod-thumb { width: 44px; height: 44px; border-radius: 8px; object-fit: cover; background: #f0f2f5; }
    .prod-thumb-placeholder { width: 44px; height: 44px; border-radius: 8px; background: #f0f2f5; display:flex; align-items:center; justify-content:center; }
    .badge { display:inline-block; padding: 3px 10px; border-radius: 100px; font-size: 0.72rem; font-weight: 700; }
    .badge-active { background: #D1FAE5; color: #065F46; }
    .badge-inactive { background: #FEE2E2; color: #991B1B; }
    .action-btns { display: flex; gap: 6px; }
    .btn-icon {
      width: 32px; height: 32px; border-radius: 8px; border: 1.5px solid var(--border);
      background: white; cursor: pointer; display: flex; align-items: center; justify-content: center;
      transition: all .15s; color: var(--text-sub);
    }
    .btn-icon:hover { border-color: var(--green); color: var(--green); }
    .btn-icon.danger:hover { border-color: var(--danger); color: var(--danger); }
    .price-cell { font-weight: 700; }
    .profit-cell { color: var(--green-dark); font-weight: 600; }

    /* ── MODAL ──────────────────────────────────────────────── */
    .modal-overlay {
      position: fixed; inset: 0; background: rgba(0,0,0,.5); z-index: 200;
      display: none; align-items: center; justify-content: center; padding: 1rem;
    }
    .modal-overlay.open { display: flex; }
    .modal {
      background: white; border-radius: 20px; width: min(560px, 100%);
      max-height: 90vh; overflow-y: auto; box-shadow: 0 20px 60px rgba(0,0,0,.25);
    }
    .modal-header { padding: 1.5rem 1.5rem 0; display: flex; align-items: center; justify-content: space-between; }
    .modal-title { font-size: 1.1rem; font-weight: 800; }
    .modal-close { width: 32px; height: 32px; border-radius: 8px; border: none; background: var(--bg); cursor: pointer; font-size: 1.1rem; display:flex; align-items:center; justify-content:center; }
    .modal-body { padding: 1.5rem; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .form-group { margin-bottom: 1.1rem; }
    .form-group label { display:block; font-size: 0.78rem; font-weight: 700; margin-bottom: 6px; color: var(--text-sub); }
    .form-group input, .form-group textarea, .form-group select {
      width: 100%; padding: 0.65rem 0.9rem; border: 1.5px solid var(--border);
      border-radius: 10px; font-family: inherit; font-size: 0.875rem; outline: none; transition: border-color .2s; color: var(--text);
    }
    .form-group input:focus, .form-group textarea:focus, .form-group select:focus { border-color: var(--green); }
    .form-group textarea { resize: vertical; min-height: 80px; }
    .img-upload-area {
      border: 2px dashed var(--border); border-radius: 12px; padding: 1.5rem;
      text-align: center; cursor: pointer; transition: border-color .2s;
    }
    .img-upload-area:hover { border-color: var(--green); }
    .img-preview { max-width: 100%; max-height: 160px; border-radius: 8px; margin-bottom: 8px; }
    .modal-footer { padding: 0 1.5rem 1.5rem; display: flex; gap: 10px; justify-content: flex-end; }
    .btn-cancel {
      padding: 0.7rem 1.5rem; border-radius: 10px; border: 1.5px solid var(--border);
      background: white; font-family: inherit; font-size: 0.875rem; font-weight: 600; cursor: pointer;
    }
    .btn-save {
      padding: 0.7rem 1.75rem; border-radius: 10px; border: none;
      background: var(--green); color: white; font-family: inherit; font-size: 0.875rem; font-weight: 700; cursor: pointer;
    }
    .btn-save:hover { background: var(--green-dark); }

    /* ── TOAST ──────────────────────────────────────────────── */
    .toast-admin {
      position: fixed; top: 1.5rem; right: 1.5rem;
      background: #1A1A2E; color: white; padding: 12px 20px; border-radius: 12px;
      font-size: 0.875rem; font-weight: 600; box-shadow: 0 8px 30px rgba(0,0,0,.25); z-index: 999;
      display: none; align-items: center; gap: 8px;
    }
    .toast-admin.show { display: flex; }
    .toast-admin.success { background: var(--green-dark); }
    .toast-admin.error { background: var(--danger); }

    /* ── EMPTY & LOADER ──────────────────────────────────────── */
    .tbl-empty { text-align:center; padding: 3rem; color: var(--text-sub); }
    .tbl-loader { text-align:center; padding: 2rem; color: var(--text-sub); }

    @media (max-width: 768px) {
      .sidebar { width: 60px; }
      .sidebar-logo-text, .sidebar-logo-sub, .nav-item span, .user-name, .btn-logout { display: none; }
      .sidebar-logo { justify-content: center; }
      .main-content { margin-left: 60px; padding: 1rem; }
      .form-row { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<!-- LOGIN -->
<div id="login-screen">
  <div class="login-card">
    <div class="login-logo">
      <div class="login-logo-icon"><svg viewBox="0 0 24 24"><path d="M20 7H4a2 2 0 00-2 2v10a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z"/></svg></div>
      <div><div class="login-logo-text">Jastip Store</div><div class="login-logo-sub">Admin Panel</div></div>
    </div>
    <h2>Selamat Datang</h2>
    <p>Login untuk mengelola produk dan inventory</p>
    <div class="field"><label>Username</label><input type="text" id="login-user" placeholder="admin" /></div>
    <div class="field"><label>Password</label><input type="password" id="login-pass" placeholder="••••••••" /></div>
    <button class="btn-primary" onclick="doLogin()">Masuk</button>
    <div class="login-error" id="login-error"></div>
  </div>
</div>

<!-- APP -->
<div id="app-screen">
  <div class="sidebar">
    <div class="sidebar-logo">
      <div class="sidebar-logo-icon"><svg viewBox="0 0 24 24"><path d="M20 7H4a2 2 0 00-2 2v10a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z"/></svg></div>
      <div><div class="sidebar-logo-text">Jastip</div><div class="sidebar-logo-sub">Admin</div></div>
    </div>
    <nav class="sidebar-nav">
      <div class="nav-item active" onclick="showPage('products')">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
        <span>Produk</span>
      </div>
      <div class="nav-item" onclick="showPage('settings')">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
        <span>Pengaturan</span>
      </div>
      <a href="/" target="_blank" style="text-decoration:none">
        <div class="nav-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          <span>Lihat Katalog</span>
        </div>
      </a>
    </nav>
    <div class="sidebar-footer">
      <div class="user-info">
        <div class="user-avatar" id="user-initial">A</div>
        <div class="user-name" id="user-name-display">Admin</div>
      </div>
      <button class="btn-logout" onclick="logout()">Keluar</button>
    </div>
  </div>

  <div class="main-content">
    <!-- PRODUCTS PAGE -->
    <div id="page-products">
      <div class="topbar">
        <div>
          <div class="page-title">Manajemen Produk</div>
          <div class="page-sub">Kelola semua produk jastip kamu</div>
        </div>
      </div>
      <div class="stats-row">
        <div class="stat-card"><div class="stat-card-label">Total Produk</div><div class="stat-card-num" id="s-total">—</div></div>
        <div class="stat-card"><div class="stat-card-label">Produk Aktif</div><div class="stat-card-num green" id="s-active">—</div></div>
        <div class="stat-card"><div class="stat-card-label">Total Stok</div><div class="stat-card-num orange" id="s-stock">—</div></div>
      </div>
      <div class="card-panel">
        <div class="card-panel-header">
          <span class="card-panel-title">Daftar Produk</span>
          <div style="display:flex;gap:10px;flex-wrap:wrap">
            <input class="search-sm" type="text" id="admin-search" placeholder="🔍 Cari produk..." oninput="filterTable()" />
            <button class="btn-add" onclick="openModal()">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Tambah Produk
            </button>
          </div>
        </div>
        <div style="overflow-x:auto">
          <table>
            <thead>
              <tr>
                <th>Produk</th>
                <th>Kategori</th>
                <th>Harga Jual</th>
                <th>Harga Modal</th>
                <th>Profit</th>
                <th>Stok</th>
                <th>Status</th>
                <th>Aksi</th>
              </tr>
            </thead>
            <tbody id="prod-tbody">
              <tr><td colspan="8" class="tbl-loader">Memuat data...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- SETTINGS PAGE -->
    <div id="page-settings" style="display:none">
      <div class="topbar">
        <div><div class="page-title">Pengaturan</div><div class="page-sub">Ubah password akun admin</div></div>
      </div>
      <div class="card-panel" style="max-width:420px;padding:1.5rem">
        <div class="modal-title" style="margin-bottom:1.25rem">Ganti Password</div>
        <div class="form-group"><label>Password Lama</label><input type="password" id="pw-old" /></div>
        <div class="form-group"><label>Password Baru</label><input type="password" id="pw-new" /></div>
        <div class="form-group"><label>Konfirmasi Password Baru</label><input type="password" id="pw-confirm" /></div>
        <button class="btn-save" style="width:100%" onclick="changePassword()">Simpan Password</button>
      </div>
    </div>
  </div>
</div>

<!-- MODAL TAMBAH/EDIT PRODUK -->
<div class="modal-overlay" id="modal-overlay">
  <div class="modal">
    <div class="modal-header">
      <span class="modal-title" id="modal-title">Tambah Produk</span>
      <button class="modal-close" onclick="closeModal()">✕</button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="prod-id" />
      <div class="form-group">
        <label>Gambar Produk</label>
        <div class="img-upload-area" onclick="document.getElementById('img-input').click()">
          <img id="img-preview-el" class="img-preview" style="display:none" />
          <div id="img-placeholder">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#9CA3AF" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            <p style="font-size:.8rem;color:#9CA3AF;margin-top:8px">Klik untuk upload gambar (max 5MB)</p>
          </div>
        </div>
        <input type="file" id="img-input" accept="image/*" style="display:none" onchange="previewImage(this)" />
      </div>
      <div class="form-group"><label>Nama Produk *</label><input type="text" id="f-name" placeholder="e.g. Tas Kulit Premium" /></div>
      <div class="form-group"><label>Deskripsi</label><textarea id="f-desc" placeholder="Deskripsi singkat produk..."></textarea></div>
      <div class="form-row">
        <div class="form-group"><label>Harga Jual (Rp) *</label><input type="number" id="f-sell" placeholder="350000" /></div>
        <div class="form-group"><label>Harga Modal (Rp) *</label><input type="number" id="f-cost" placeholder="200000" /></div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label>Kategori</label>
          <select id="f-cat">
            <option>Fashion</option><option>Kecantikan</option><option>Elektronik</option><option>Aksesori</option><option>Makanan</option><option>Umum</option>
          </select>
        </div>
        <div class="form-group"><label>Stok</label><input type="number" id="f-stock" placeholder="0" min="0" /></div>
      </div>
      <div class="form-group" id="f-active-wrap" style="display:none">
        <label>Status</label>
        <select id="f-active"><option value="1">Aktif</option><option value="0">Nonaktif</option></select>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn-cancel" onclick="closeModal()">Batal</button>
      <button class="btn-save" onclick="saveProduct()">Simpan Produk</button>
    </div>
  </div>
</div>

<!-- TOAST -->
<div class="toast-admin" id="admin-toast"></div>

<script>
  let token = localStorage.getItem('jastip_token');
  let adminUser = localStorage.getItem('jastip_user');
  let allProds = [];

  // ── AUTH ──────────────────────────────────────────────────
  async function doLogin() {
    const username = document.getElementById('login-user').value;
    const password = document.getElementById('login-pass').value;
    const err = document.getElementById('login-error');
    if (!username || !password) { err.textContent = 'Isi username dan password'; return; }
    try {
      const r = await fetch('/api/auth/login', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({username, password}) });
      const d = await r.json();
      if (!r.ok) { err.textContent = d.error; return; }
      token = d.token; adminUser = d.username;
      localStorage.setItem('jastip_token', token);
      localStorage.setItem('jastip_user', adminUser);
      showApp();
    } catch { err.textContent = 'Gagal konek ke server'; }
  }

  function logout() {
    localStorage.removeItem('jastip_token');
    localStorage.removeItem('jastip_user');
    token = null;
    document.getElementById('login-screen').style.display = 'flex';
    document.getElementById('app-screen').style.display = 'none';
    document.getElementById('login-pass').value = '';
    document.getElementById('login-error').textContent = '';
  }

  function showApp() {
    document.getElementById('login-screen').style.display = 'none';
    document.getElementById('app-screen').style.display = 'block';
    document.getElementById('user-initial').textContent = adminUser?.[0]?.toUpperCase() || 'A';
    document.getElementById('user-name-display').textContent = adminUser;
    loadProducts();
  }

  document.getElementById('login-pass').addEventListener('keydown', e => { if(e.key==='Enter') doLogin(); });

  // ── PAGES ─────────────────────────────────────────────────
  function showPage(p) {
    document.querySelectorAll('[id^=page-]').forEach(el => el.style.display = 'none');
    document.getElementById(`page-${p}`).style.display = 'block';
    document.querySelectorAll('.nav-item').forEach((el,i) => el.classList.toggle('active', i === ({'products':0,'settings':1}[p])));
  }

  // ── PRODUCTS ──────────────────────────────────────────────
  function fmt(n) { return 'Rp '+Number(n).toLocaleString('id-ID'); }

  async function loadProducts() {
    const r = await fetch('/api/admin/products', { headers:{ Authorization:'Bearer '+token } });
    if (r.status === 401) { logout(); return; }
    allProds = await r.json();
    renderTable(allProds);
    document.getElementById('s-total').textContent = allProds.length;
    document.getElementById('s-active').textContent = allProds.filter(p=>p.active).length;
    document.getElementById('s-stock').textContent = allProds.reduce((a,p)=>a+(p.stock||0),0);
  }

  function filterTable() {
    const q = document.getElementById('admin-search').value.toLowerCase();
    renderTable(q ? allProds.filter(p => p.name.toLowerCase().includes(q)) : allProds);
  }

  function renderTable(prods) {
    const tbody = document.getElementById('prod-tbody');
    if (!prods.length) { tbody.innerHTML = `<tr><td colspan="8" class="tbl-empty">Belum ada produk</td></tr>`; return; }
    tbody.innerHTML = prods.map(p => `
      <tr>
        <td><div style="display:flex;align-items:center;gap:10px">
          ${p.image ? `<img class="prod-thumb" src="${p.image}" />` : `<div class="prod-thumb-placeholder"><svg width="20" height="20" viewBox="0 0 24 24" fill="#D1D5DB"><path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2z"/></svg></div>`}
          <span style="font-weight:600">${p.name}</span>
        </div></td>
        <td><span style="color:var(--text-sub)">${p.category||'Umum'}</span></td>
        <td class="price-cell">${fmt(p.price_sell)}</td>
        <td style="color:var(--text-sub)">${fmt(p.price_cost)}</td>
        <td class="profit-cell">+${fmt(p.price_sell - p.price_cost)}</td>
        <td>${p.stock||0}</td>
        <td><span class="badge ${p.active?'badge-active':'badge-inactive'}">${p.active?'Aktif':'Nonaktif'}</span></td>
        <td><div class="action-btns">
          <button class="btn-icon" onclick="editProduct(${p.id})" title="Edit">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          </button>
          <button class="btn-icon danger" onclick="deleteProduct(${p.id},'${p.name.replace(/'/g,"\\'")}')">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4h6v2"/></svg>
          </button>
        </div></td>
      </tr>
    `).join('');
  }

  // ── MODAL ─────────────────────────────────────────────────
  function openModal(prod = null) {
    document.getElementById('modal-title').textContent = prod ? 'Edit Produk' : 'Tambah Produk';
    document.getElementById('prod-id').value = prod?.id || '';
    document.getElementById('f-name').value = prod?.name || '';
    document.getElementById('f-desc').value = prod?.description || '';
    document.getElementById('f-sell').value = prod?.price_sell || '';
    document.getElementById('f-cost').value = prod?.price_cost || '';
    document.getElementById('f-cat').value = prod?.category || 'Umum';
    document.getElementById('f-stock').value = prod?.stock || 0;
    document.getElementById('f-active').value = prod?.active !== undefined ? prod.active : 1;
    document.getElementById('f-active-wrap').style.display = prod ? 'block' : 'none';
    document.getElementById('img-input').value = '';
    const preview = document.getElementById('img-preview-el');
    const placeholder = document.getElementById('img-placeholder');
    if (prod?.image) { preview.src = prod.image; preview.style.display='block'; placeholder.style.display='none'; }
    else { preview.style.display='none'; placeholder.style.display='block'; }
    document.getElementById('modal-overlay').classList.add('open');
  }

  function closeModal() { document.getElementById('modal-overlay').classList.remove('open'); }

  function previewImage(input) {
    if (!input.files[0]) return;
    const url = URL.createObjectURL(input.files[0]);
    document.getElementById('img-preview-el').src = url;
    document.getElementById('img-preview-el').style.display = 'block';
    document.getElementById('img-placeholder').style.display = 'none';
  }

  async function editProduct(id) {
    const prod = allProds.find(p => p.id === id);
    if (prod) openModal(prod);
  }

  async function saveProduct() {
    const id = document.getElementById('prod-id').value;
    const name = document.getElementById('f-name').value.trim();
    const price_sell = document.getElementById('f-sell').value;
    const price_cost = document.getElementById('f-cost').value;
    if (!name || !price_sell || !price_cost) { showToast('Nama dan harga wajib diisi', 'error'); return; }

    const fd = new FormData();
    fd.append('name', name);
    fd.append('description', document.getElementById('f-desc').value);
    fd.append('price_sell', price_sell);
    fd.append('price_cost', price_cost);
    fd.append('category', document.getElementById('f-cat').value);
    fd.append('stock', document.getElementById('f-stock').value || 0);
    if (id) fd.append('active', document.getElementById('f-active').value);
    const imgFile = document.getElementById('img-input').files[0];
    if (imgFile) fd.append('image', imgFile);

    const url = id ? `/api/admin/products/${id}` : '/api/admin/products';
    const method = id ? 'PUT' : 'POST';
    const r = await fetch(url, { method, headers:{ Authorization:'Bearer '+token }, body: fd });
    const d = await r.json();
    if (!r.ok) { showToast(d.error || 'Gagal menyimpan', 'error'); return; }
    closeModal();
    showToast(d.message || 'Produk tersimpan', 'success');
    loadProducts();
  }

  async function deleteProduct(id, name) {
    if (!confirm(`Hapus produk "${name}"?`)) return;
    const r = await fetch(`/api/admin/products/${id}`, { method:'DELETE', headers:{ Authorization:'Bearer '+token } });
    const d = await r.json();
    showToast(d.message, 'success');
    loadProducts();
  }

  // ── SETTINGS ─────────────────────────────────────────────
  async function changePassword() {
    const current_password = document.getElementById('pw-old').value;
    const new_password = document.getElementById('pw-new').value;
    const confirm = document.getElementById('pw-confirm').value;
    if (new_password !== confirm) { showToast('Konfirmasi password tidak cocok', 'error'); return; }
    if (new_password.length < 6) { showToast('Password minimal 6 karakter', 'error'); return; }
    const r = await fetch('/api/admin/password', { method:'PUT', headers:{ Authorization:'Bearer '+token, 'Content-Type':'application/json' }, body: JSON.stringify({current_password, new_password}) });
    const d = await r.json();
    showToast(d.message || d.error, r.ok ? 'success' : 'error');
    if (r.ok) { document.getElementById('pw-old').value=''; document.getElementById('pw-new').value=''; document.getElementById('pw-confirm').value=''; }
  }

  // ── TOAST ─────────────────────────────────────────────────
  function showToast(msg, type = 'success') {
    const t = document.getElementById('admin-toast');
    t.textContent = msg; t.className = `toast-admin show ${type}`;
    setTimeout(() => t.classList.remove('show'), 3000);
  }

  // ── INIT ──────────────────────────────────────────────────
  if (token) showApp();
</script>
</body>
</html>
